# Zmienne konfiguracyjne aplikacji (skopiuj ten plik jako .env)

# Klucz tajny do podpisywania tokenów JWT (wygeneruj silny klucz np. za pomocą openssl rand -hex 32)
SECRET_KEY=b3d9f131a980998a44490f230bbd743a13915bc828882ca1a6b0c20ab0d9e262

# Algorytm kodowania JWT
ALGORITHM=HS256

# Czas życia tokenu dostępu w minutach
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Adres URL do bazy danych (SQLite dla lokalnego uruchomienia, PostgreSQL w Dockerze)
# SQLite (lokalnie):
DATABASE_URL=sqlite:///./test.db

# PostgreSQL (Docker):
# DATABASE_URL=postgresql://catalog_user:catalog_password@db:5432/movie_catalog
